{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Design system of the bce.design quickstarter — a bookmarks SPA that showcases web standards, replacing proprietary and custom code with platform capabilities.",
  "color": {
    "$type": "color",
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.82,
          0.698
        ],
        "hex": "#00d1b2"
      }
    },
    "primary-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0.769,
          0.655
        ],
        "hex": "#00c4a7"
      }
    },
    "on-primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.024,
          0.165,
          0.145
        ],
        "hex": "#062a25"
      }
    },
    "secondary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.196,
          0.451,
          0.863
        ],
        "hex": "#3273dc"
      }
    },
    "neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.961,
          0.961,
          0.961
        ],
        "hex": "#f5f5f5"
      }
    },
    "neutral-hover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.933,
          0.933,
          0.933
        ],
        "hex": "#eeeeee"
      }
    },
    "on-neutral": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0,
          0,
          0
        ],
        "hex": "#000000b3"
      }
    },
    "surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          1,
          1,
          1
        ],
        "hex": "#ffffff"
      }
    },
    "on-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.29,
          0.29,
          0.29
        ],
        "hex": "#4a4a4a"
      }
    },
    "on-surface-strong": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.212,
          0.212,
          0.212
        ],
        "hex": "#363636"
      }
    },
    "danger": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.8,
          0.059,
          0.208
        ],
        "hex": "#cc0f35"
      }
    },
    "danger-surface": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.996,
          0.925,
          0.941
        ],
        "hex": "#feecf0"
      }
    },
    "accent-border": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.8,
          0.953,
          0.925
        ],
        "hex": "#ccf3ec"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "xs": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    },
    "xl": {
      "$value": {
        "value": 32,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 2,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    }
  },
  "typography": {
    "headline-lg": {
      "$type": "typography",
      "$value": {
        "fontFamily": "system-ui",
        "fontSize": {
          "value": 32,
          "unit": "px"
        },
        "fontWeight": 600
      }
    },
    "body-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "system-ui",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 400
      }
    },
    "label-md": {
      "$type": "typography",
      "$value": {
        "fontFamily": "system-ui",
        "fontSize": {
          "value": 16,
          "unit": "px"
        },
        "fontWeight": 700
      }
    },
    "label-sm": {
      "$type": "typography",
      "$value": {
        "fontFamily": "system-ui",
        "fontSize": {
          "value": 12,
          "unit": "px"
        },
        "fontWeight": 400
      }
    }
  }
}